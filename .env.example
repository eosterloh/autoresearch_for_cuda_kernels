# Copy this file to .env and fill in your values.
# Source it before running: source .env  (or use python-dotenv)

# ── Anthropic (smart LLM fallback) ──────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram (human-in-the-loop) ────────────────────────────────────
# 1. Create a bot via @BotFather → /newbot → copy the token below
# 2. Send a message to your bot, then call:
#    curl https://api.telegram.org/bot<TOKEN>/getUpdates
#    Copy the "id" from result[0].message.chat.id
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_CHAT_ID=987654321

# ── HuggingFace Hub ─────────────────────────────────────────────────
# Get from: https://huggingface.co/settings/tokens
# Also accept the Gemma 3 licence at:
# https://huggingface.co/google/gemma-3-12b
HF_TOKEN=hf_...

# ── GitHub (RAG corpus seeding) ──────────────────────────────────────
# Personal access token with public repo read access.
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# ── Ollama ───────────────────────────────────────────────────────────
# Default: local Ollama instance. Override if running remotely.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nemotron-3-nano:30b
OLLAMA_TIMEOUT_SECONDS=120

# ── Anthropic model ─────────────────────────────────────────────────
ANTHROPIC_MODEL=claude-opus-4-8

# ── Loop tuning ──────────────────────────────────────────────────────
MAX_SESSION_TOKENS=2000000   # cap on Anthropic API tokens only; Ollama (local) is unlimited
TIME_BUDGET_HOURS=24
CONTEXT_WINDOW_MAX_MESSAGES=40
